# Run lint-staged per workspace so each uses its own eslint.config.js
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

run_lint_staged() {
  local dir="$1"
  if echo "$STAGED_FILES" | grep -q "^${dir}/"; then
    (cd "$dir" && npx lint-staged --relative)
  fi
}

run_lint_staged "pokeradar-client"
run_lint_staged "pokeradar-api"
run_lint_staged "pokeradar-scrapper"
run_lint_staged "pokeradar-notifications"
run_lint_staged "packages/shared"

# Determine which workspaces have staged TypeScript files
TYPECHECK_FAILED=0

check_workspace() {
  local prefix="$1"
  local workspace="$2"

  if echo "$STAGED_FILES" | grep -q "^${prefix}/.*\.tsx\?$"; then
    echo "Typechecking ${workspace}..."
    npm run typecheck -w "$workspace"
    if [ $? -ne 0 ]; then
      TYPECHECK_FAILED=1
    fi
  fi
}

check_workspace "packages/shared" "@pokeradar/shared"
check_workspace "pokeradar-api" "pokeradar-api"
check_workspace "pokeradar-client" "pokeradar-client"
check_workspace "pokeradar-scrapper" "pokeradar-scrapper"
check_workspace "pokeradar-notifications" "pokeradar-notifications"

if [ $TYPECHECK_FAILED -ne 0 ]; then
  echo ""
  echo "TypeScript type checking failed. Fix the errors above before committing."
  exit 1
fi

# Check if any scrapper files are being committed
SCRAPPER_FILES=$(echo "$STAGED_FILES" | grep "^pokeradar-scrapper/" || true)

if [ -n "$SCRAPPER_FILES" ]; then
  echo "Scrapper files changed - running baseline:check..."
  echo ""

  # Check if baseline file exists
  if [ ! -f "pokeradar-scrapper/scripts/baseline/fixtures/_baseline.json" ]; then
    echo "Warning: No baseline found. Run 'npm run baseline:record -w pokeradar-scrapper' first."
    echo "Skipping baseline check..."
    exit 0
  fi

  # Run baseline check
  npm run baseline:check -w pokeradar-scrapper

  if [ $? -ne 0 ]; then
    echo ""
    echo "Baseline check failed! Your changes broke the scrapper."
    echo ""
    echo "Options:"
    echo "  1. Fix the regressions in your code"
    echo "  2. If changes are intentional, re-record baseline:"
    echo "     npm run baseline:record -w pokeradar-scrapper"
    echo "  3. To skip this check once: git commit --no-verify"
    echo ""
    exit 1
  fi

  echo ""
  echo "Baseline check passed!"
  echo ""
fi
