{
  "id": "gnom-sklep",
  "name": "Gnom Sklep",
  "baseUrl": "https://gnom-sklep.pl",
  "searchUrl": "/pl/search?text={query}",
  "selectors": {
    "searchPage": {
      "article": {
        "type": "css",
        "value": "div.product"
      },
      "productUrl": {
        "type": "css",
        "value": "a.product__name",
        "extract": "href"
      },
      "title": {
        "type": "css",
        "value": "a.product__name"
      },
      "price": {
        "type": "css",
        "value": "strong.price.--main",
        "format": "european"
      },
      "unavailable": {
        "type": "css",
        "value": "div.product[data-product_disable='true']",
        "matchSelf": true
      },
      "available": {
        "type": "css",
        "value": "div.product:not([data-product_disable='true'])",
        "matchSelf": true
      }
    },
    "productPage": {
      "price": {
        "type": "css",
        "value": "h2.projector_prices__price",
        "format": "european"
      },
      "available": {
        "type": "css",
        "value": "a.projector_sizes__item:not(.--disabled)"
      }
    }
  }
}
