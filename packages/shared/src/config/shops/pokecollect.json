{
  "id": "pokecollect",
  "name": "PokeCollect",
  "baseUrl": "https://pokecollect.pl",
  "searchUrl": "/pl/searchquery/{query}/1/phot/5",
  "selectors": {
    "searchPage": {
      "article": {
        "type": "css",
        "value": "div.product"
      },
      "productUrl": {
        "type": "css",
        "value": "a.prodname",
        "extract": "href"
      },
      "title": {
        "type": "css",
        "value": "span.productname"
      },
      "price": {
        "type": "css",
        "value": "div.price em",
        "format": "european"
      },
      "available": {
        "type": "css",
        "value": "button.addtobasket:not([disabled])"
      },
      "unavailable": {
        "type": "css",
        "value": "a.quickview"
      }
    },
    "productPage": {
      "price": {
        "type": "css",
        "value": "div.maininfo em.main-price",
        "format": "european"
      },
      "available": {
        "type": "css",
        "value": "fieldset.addtobasket-container:not(.none) button.addtobasket"
      }
    }
  }
}
