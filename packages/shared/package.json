{
  "name": "@pokeradar/shared",
  "version": "1.0.0",
  "description": "Shared models, logger, and database utilities for pokeradar services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && npm run copy-configs",
    "copy-configs": "node scripts/copy-configs.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mongoose": "^9.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.9",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --no-warn-ignored",
      "prettier --write"
    ],
    "*.{js,jsx,json,md}": "prettier --write"
  }
}
