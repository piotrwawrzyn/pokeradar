{
  "name": "pokeradar-scrapper",
  "version": "1.0.0",
  "description": "",
  "main": "dist/app/index.js",
  "scripts": {
    "build": "npm run build -w @pokeradar/shared && tsc",
    "start": "node dist/app/index.js",
    "dev": "ts-node src/app/index.ts",
    "postinstall": "npx playwright install",
    "check": "tsx scripts/check-watchlist.ts",
    "baseline": "tsx scripts/baseline.ts",
    "baseline:check": "tsx scripts/baseline.ts --check",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cheerio": "^1.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.0.9",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "playwright": "^1.57.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@pokeradar/shared": "*",
    "axios": "^1.13.2",
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3",
    "fuzzball": "^2.2.3",
    "https-proxy-agent": "^7.0.6",
    "mongoose": "^9.1.5",
    "patchright": "^1.57.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --no-warn-ignored",
      "prettier --write"
    ],
    "*.{js,jsx,json,md}": "prettier --write"
  }
}
